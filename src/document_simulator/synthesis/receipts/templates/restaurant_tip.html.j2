<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  @page {
    /* Restaurant: slightly wider than thermal, still single column */
    size: 88mm 220mm;
    margin: 3mm;
  }
  html, body { margin: 0; padding: 0; background: #ffffff; color: #000; }
  body {
    font-family: "Menlo", "Consolas", ui-monospace, monospace;
    font-size: 10pt;
    line-height: 1.3;
  }
  .center { text-align: center; }
  .row    { display: flex; justify-content: space-between; }
  .row .left  { flex: 1 1 auto; text-align: left; }
  .row .right { flex: 0 0 auto; text-align: right; }
  hr      { border: none; border-top: 1px dashed #000; margin: 5px 0; }
  .meta   { font-size: 9pt; }
  .totals { margin-top: 4px; }
  .tipline { margin-top: 4px; padding-top: 4px; border-top: 1px solid #000; }
</style>
</head>
<body>

<div class="center">
  <span data-token-id="merchant">{{ receipt.merchant }}</span>
</div>
<div class="center meta">
  <span data-token-id="address">{{ receipt.address }}</span>
</div>

<hr>

<div class="row meta">
  <span class="left">SERVER: <span data-token-id="server">ALEX</span></span>
  <span class="right">TABLE <span data-token-id="table">12</span></span>
</div>

<hr>

{% for item in receipt.items %}
<div class="row">
  <span class="left">
    <span data-token-id="item_{{ loop.index0 }}_qty">{{ item.qty }}</span>
    x
    <span data-token-id="item_{{ loop.index0 }}_sku">{{ item.sku }}</span>
  </span>
  <span class="right">
    <span data-token-id="item_{{ loop.index0 }}_price">{{ "%.2f"|format(item.total) }}</span>
  </span>
</div>
{% endfor %}

<hr>

<div class="row totals">
  <span class="left">SUBTOTAL</span>
  <span class="right"><span data-token-id="subtotal">{{ "%.2f"|format(receipt.subtotal) }}</span></span>
</div>
<div class="row">
  <span class="left">TAX</span>
  <span class="right"><span data-token-id="tax">{{ "%.2f"|format(receipt.tax) }}</span></span>
</div>
<div class="row">
  <span class="left">TOTAL</span>
  <span class="right"><span data-token-id="total">{{ "%.2f"|format(receipt.total) }}</span></span>
</div>

<div class="tipline">
  <div class="row">
    <span class="left">TIP 15%</span>
    <span class="right"><span data-token-id="tip_15">{{ "%.2f"|format(receipt.subtotal * 0.15) }}</span></span>
  </div>
  <div class="row">
    <span class="left">TIP 18%</span>
    <span class="right"><span data-token-id="tip_18">{{ "%.2f"|format(receipt.subtotal * 0.18) }}</span></span>
  </div>
  <div class="row">
    <span class="left">TIP 20%</span>
    <span class="right"><span data-token-id="tip_20">{{ "%.2f"|format(receipt.subtotal * 0.20) }}</span></span>
  </div>
  <div class="row">
    <span class="left">TIP _____</span>
    <span class="right">________</span>
  </div>
  <div class="row">
    <span class="left">TOTAL ___</span>
    <span class="right">________</span>
  </div>
</div>

<hr>

<div class="center meta">
  CARD ****<span data-token-id="payment">{{ receipt.payment_last4 }}</span>
</div>
<div class="center meta">THANK YOU!</div>

</body>
</html>
