# Example Streamlit secrets file.
# Copy to secrets.toml and fill in your values, then paste into
# https://share.streamlit.io → App settings → Secrets
#
# secrets.toml is gitignored — never commit it.

[project]
PROJECT_NAME = "document-simulator"
ENVIRONMENT = "development"

[paths]
DATA_DIR = "./data"
MODELS_DIR = "./models"
OUTPUT_DIR = "./output"
LOGS_DIR = "./logs"

[augraphy]
AUGRAPHY_CACHE_DIR = "./cache/augraphy"
AUGRAPHY_NUM_WORKERS = 4

[paddleocr]
PADDLEOCR_USE_GPU = false
PADDLEOCR_LANG = "en"
PADDLEOCR_DET_MODEL_DIR = "./models/paddle/det"
PADDLEOCR_REC_MODEL_DIR = "./models/paddle/rec"
PADDLEOCR_CLS_MODEL_DIR = "./models/paddle/cls"

[stable_baselines3]
SB3_TENSORBOARD_LOG = "./logs/tensorboard"
SB3_CHECKPOINT_DIR = "./checkpoints"

[training]
BATCH_SIZE = 32
NUM_EPOCHS = 100
LEARNING_RATE = 0.001
RANDOM_SEED = 42

[wandb]
# WANDB_API_KEY = "your_wandb_api_key_here"
# WANDB_PROJECT = "document-simulator"
# WANDB_ENTITY = "your_username"

[pytorch]
PYTORCH_CUDA_ALLOC_CONF = "expandable_segments:True"
TORCH_HOME = "./cache/torch"

[logging]
LOG_LEVEL = "INFO"
LOG_FORMAT = "text"

[performance]
NUM_WORKERS = 4
PREFETCH_FACTOR = 2
PIN_MEMORY = true
