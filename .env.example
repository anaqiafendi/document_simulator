# Environment Configuration for Document Simulator

# Project Settings
PROJECT_NAME=document-simulator
ENVIRONMENT=development  # development, staging, production

# Paths
DATA_DIR=./data
MODELS_DIR=./models
OUTPUT_DIR=./output
LOGS_DIR=./logs

# Augraphy Settings
AUGRAPHY_CACHE_DIR=./cache/augraphy
AUGRAPHY_NUM_WORKERS=4

# PaddleOCR Settings
PADDLEOCR_USE_GPU=false
PADDLEOCR_LANG=en
PADDLEOCR_DET_MODEL_DIR=./models/paddle/det
PADDLEOCR_REC_MODEL_DIR=./models/paddle/rec
PADDLEOCR_CLS_MODEL_DIR=./models/paddle/cls

# Stable-Baselines3 Settings
SB3_TENSORBOARD_LOG=./logs/tensorboard
SB3_CHECKPOINT_DIR=./checkpoints

# Training Settings
BATCH_SIZE=32
NUM_EPOCHS=100
LEARNING_RATE=0.001
RANDOM_SEED=42

# Weights & Biases (Optional)
# WANDB_API_KEY=your_wandb_api_key_here
# WANDB_PROJECT=document-simulator
# WANDB_ENTITY=your_username

# PyTorch Settings
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
TORCH_HOME=./cache/torch

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=text  # text, json

# Performance
NUM_WORKERS=4
PREFETCH_FACTOR=2
PIN_MEMORY=true
